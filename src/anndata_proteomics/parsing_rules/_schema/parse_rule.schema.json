{
  "$defs": {
    "Axis": {
      "additionalProperties": false,
      "properties": {
        "obs_keys": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Obs Keys",
          "type": "array"
        },
        "var_keys": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Var Keys",
          "type": "array"
        },
        "x_layer": {
          "title": "X Layer",
          "type": "string"
        }
      },
      "required": [
        "obs_keys",
        "var_keys",
        "x_layer"
      ],
      "title": "Axis",
      "type": "object"
    },
    "Columns": {
      "additionalProperties": false,
      "properties": {
        "obs": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Obs",
          "type": "object"
        },
        "var": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Var",
          "type": "object"
        }
      },
      "required": [
        "obs",
        "var"
      ],
      "title": "Columns",
      "type": "object"
    },
    "Duplicates": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "default": "error",
          "enum": [
            "error",
            "aggregate",
            "keep_first",
            "keep_all_as_raw_table"
          ],
          "title": "Mode",
          "type": "string"
        }
      },
      "title": "Duplicates",
      "type": "object"
    },
    "Layer": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "encoding_mode": {
          "default": "numeric",
          "enum": [
            "numeric",
            "factor"
          ],
          "title": "Encoding Mode",
          "type": "string"
        },
        "categories": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Categories"
        },
        "source_column": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Column"
        },
        "column_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Column Pattern"
        }
      },
      "required": [
        "name"
      ],
      "title": "Layer",
      "type": "object"
    },
    "ModificationMapEntry": {
      "additionalProperties": false,
      "description": "User-facing TOML entry: a vendor token plus the Unimod accession.\n\n``name``, ``target``, ``position`` and ``mass_delta`` are NOT carried\non the entry itself \u2014 they are filled at rule-load time from\n``modifications/unimod_registry.toml``. This keeps the per-tool TOMLs\nfree of duplicated canonical data and guarantees that all tools agree\non what e.g. ``UNIMOD:35`` means.",
      "properties": {
        "token": {
          "title": "Token",
          "type": "string"
        },
        "accession": {
          "title": "Accession",
          "type": "string"
        }
      },
      "required": [
        "token",
        "accession"
      ],
      "title": "ModificationMapEntry",
      "type": "object"
    },
    "Modifications": {
      "additionalProperties": false,
      "properties": {
        "source_column": {
          "title": "Source Column",
          "type": "string"
        },
        "parser": {
          "default": "token_regex",
          "enum": [
            "token_regex",
            "already_proforma",
            "separate_mod_column"
          ],
          "title": "Parser",
          "type": "string"
        },
        "token_pattern": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Token Pattern"
        },
        "token_position": {
          "default": "after_residue",
          "enum": [
            "before_residue",
            "after_residue",
            "n_term",
            "c_term",
            "embedded",
            "unknown"
          ],
          "title": "Token Position",
          "type": "string"
        },
        "case_sensitive": {
          "default": false,
          "title": "Case Sensitive",
          "type": "boolean"
        },
        "unknown_policy": {
          "default": "preserve",
          "enum": [
            "preserve",
            "drop",
            "error"
          ],
          "title": "Unknown Policy",
          "type": "string"
        },
        "sequence_column": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sequence Column"
        },
        "output_column": {
          "default": "proforma_sequence",
          "title": "Output Column",
          "type": "string"
        },
        "map": {
          "items": {
            "$ref": "#/$defs/ModificationMapEntry"
          },
          "title": "Map",
          "type": "array"
        }
      },
      "required": [
        "source_column"
      ],
      "title": "Modifications",
      "type": "object"
    },
    "SampleNameCleanup": {
      "additionalProperties": false,
      "properties": {
        "pattern": {
          "default": "",
          "title": "Pattern",
          "type": "string"
        }
      },
      "title": "SampleNameCleanup",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "file_version": {
      "title": "File Version",
      "type": "string"
    },
    "software_name": {
      "title": "Software Name",
      "type": "string"
    },
    "software_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Software Version"
    },
    "input_shape": {
      "enum": [
        "long",
        "wide"
      ],
      "title": "Input Shape",
      "type": "string"
    },
    "quantification_level": {
      "enum": [
        "ion",
        "peptidoform",
        "peptide",
        "protein"
      ],
      "title": "Quantification Level",
      "type": "string"
    },
    "axis": {
      "$ref": "#/$defs/Axis"
    },
    "columns": {
      "$ref": "#/$defs/Columns"
    },
    "layers": {
      "items": {
        "$ref": "#/$defs/Layer"
      },
      "minItems": 1,
      "title": "Layers",
      "type": "array"
    },
    "duplicates": {
      "$ref": "#/$defs/Duplicates"
    },
    "sample_name_cleanup": {
      "anyOf": [
        {
          "$ref": "#/$defs/SampleNameCleanup"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "modifications": {
      "anyOf": [
        {
          "$ref": "#/$defs/Modifications"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "schema_version",
    "file_version",
    "software_name",
    "input_shape",
    "quantification_level",
    "axis",
    "columns",
    "layers"
  ],
  "title": "ParseRule",
  "type": "object"
}
