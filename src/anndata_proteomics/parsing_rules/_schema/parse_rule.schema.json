{
  "$defs": {
    "AlreadyProformaModifications": {
      "additionalProperties": false,
      "description": "``source_column`` already holds a ProForma string; copy it through.",
      "properties": {
        "parser": {
          "const": "already_proforma",
          "title": "Parser",
          "type": "string"
        },
        "source_column": {
          "title": "Source Column",
          "type": "string"
        },
        "output_column": {
          "default": "proforma_sequence",
          "title": "Output Column",
          "type": "string"
        }
      },
      "required": [
        "parser",
        "source_column"
      ],
      "title": "AlreadyProformaModifications",
      "type": "object"
    },
    "Axis": {
      "additionalProperties": false,
      "properties": {
        "obs_keys": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Obs Keys",
          "type": "array"
        },
        "var_keys": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Var Keys",
          "type": "array"
        },
        "x_layer": {
          "title": "X Layer",
          "type": "string"
        },
        "duplicates": {
          "$ref": "#/$defs/Duplicates"
        }
      },
      "required": [
        "obs_keys",
        "var_keys",
        "x_layer"
      ],
      "title": "Axis",
      "type": "object"
    },
    "ColumnCompute": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "from": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "From",
          "type": "array"
        },
        "how": {
          "enum": [
            "proforma_sequence",
            "stripped_sequence",
            "proforma_ion",
            "proforma_fragment"
          ],
          "title": "How",
          "type": "string"
        }
      },
      "required": [
        "name",
        "from",
        "how"
      ],
      "title": "ColumnCompute",
      "type": "object"
    },
    "ColumnGroup": {
      "additionalProperties": false,
      "properties": {
        "select": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Select",
          "type": "object"
        },
        "compute": {
          "items": {
            "$ref": "#/$defs/ColumnCompute"
          },
          "title": "Compute",
          "type": "array"
        }
      },
      "title": "ColumnGroup",
      "type": "object"
    },
    "ColumnLabeledFragments": {
      "additionalProperties": false,
      "description": "DIA-NN exports carrying fragment identities in a packed ``label_column``.\n\n``label_column`` (e.g. ``Fragment.Info``, tokens like ``b4-unknown^1/327.16``)\nyields ``label_output`` = the token before ``/``.",
      "properties": {
        "label_strategy": {
          "const": "column",
          "title": "Label Strategy",
          "type": "string"
        },
        "value_columns": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Value Columns",
          "type": "array"
        },
        "label_column": {
          "title": "Label Column",
          "type": "string"
        },
        "delimiter": {
          "default": ";",
          "title": "Delimiter",
          "type": "string"
        },
        "label_output": {
          "default": "fragment_label",
          "title": "Label Output",
          "type": "string"
        }
      },
      "required": [
        "label_strategy",
        "value_columns",
        "label_column"
      ],
      "title": "ColumnLabeledFragments",
      "type": "object"
    },
    "Columns": {
      "additionalProperties": false,
      "properties": {
        "obs": {
          "$ref": "#/$defs/ColumnGroup"
        },
        "var": {
          "$ref": "#/$defs/ColumnGroup"
        }
      },
      "required": [
        "obs",
        "var"
      ],
      "title": "Columns",
      "type": "object"
    },
    "Duplicates": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "default": "error",
          "enum": [
            "error",
            "aggregate",
            "keep_first",
            "keep_all_as_raw_table"
          ],
          "title": "Mode",
          "type": "string"
        }
      },
      "title": "Duplicates",
      "type": "object"
    },
    "Layer": {
      "additionalProperties": false,
      "description": "A quantitative layer fed by one ``source``.\n\n``source`` interpretation is owned by the rule-level ``input_shape``:\n\n- ``input_shape=\"long\"``: ``source`` is an exact vendor column name.\n- ``input_shape=\"wide\"``: ``source`` is a regex over matrix headers and must\n  contain a ``(?P<sample>...)`` named group (enforced on ``ParseRule``).",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "encoding_mode": {
          "default": "numeric",
          "enum": [
            "numeric",
            "factor"
          ],
          "title": "Encoding Mode",
          "type": "string"
        },
        "categories": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Categories",
          "type": "object"
        }
      },
      "required": [
        "name",
        "source"
      ],
      "title": "Layer",
      "type": "object"
    },
    "ModificationMapEntry": {
      "additionalProperties": false,
      "description": "User-facing TOML entry: a vendor token plus the Unimod accession.\n\n``name``, ``target``, ``position`` and ``mass_delta`` are NOT carried\non the entry itself \u2014 they are filled at rule-load time from\n``modifications/unimod_registry.toml``. This keeps the per-tool TOMLs\nfree of duplicated canonical data and guarantees that all tools agree\non what e.g. ``UNIMOD:35`` means.",
      "properties": {
        "token": {
          "title": "Token",
          "type": "string"
        },
        "accession": {
          "title": "Accession",
          "type": "string"
        }
      },
      "required": [
        "token",
        "accession"
      ],
      "title": "ModificationMapEntry",
      "type": "object"
    },
    "PositionalFragments": {
      "additionalProperties": false,
      "description": "Older DIA-NN exports with no per-fragment label column.\n\nFragment labels are synthesised positionally (``frag_0``, ``frag_1``, \u2026) by\nindex within the precursor.",
      "properties": {
        "label_strategy": {
          "const": "positional",
          "title": "Label Strategy",
          "type": "string"
        },
        "value_columns": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Value Columns",
          "type": "array"
        },
        "delimiter": {
          "default": ";",
          "title": "Delimiter",
          "type": "string"
        },
        "label_output": {
          "default": "fragment_label",
          "title": "Label Output",
          "type": "string"
        }
      },
      "required": [
        "label_strategy",
        "value_columns"
      ],
      "title": "PositionalFragments",
      "type": "object"
    },
    "SampleNameCleanup": {
      "additionalProperties": false,
      "properties": {
        "pattern": {
          "default": "",
          "title": "Pattern",
          "type": "string"
        }
      },
      "title": "SampleNameCleanup",
      "type": "object"
    },
    "SeparateModColumnModifications": {
      "additionalProperties": false,
      "description": "Modification tokens live in a column separate from the stripped sequence.",
      "properties": {
        "parser": {
          "const": "separate_mod_column",
          "title": "Parser",
          "type": "string"
        },
        "source_column": {
          "title": "Source Column",
          "type": "string"
        },
        "sequence_column": {
          "title": "Sequence Column",
          "type": "string"
        },
        "token_position": {
          "default": "after_residue",
          "enum": [
            "before_residue",
            "after_residue",
            "n_term",
            "c_term",
            "embedded",
            "unknown"
          ],
          "title": "Token Position",
          "type": "string"
        },
        "case_sensitive": {
          "default": false,
          "title": "Case Sensitive",
          "type": "boolean"
        },
        "unknown_policy": {
          "default": "preserve",
          "enum": [
            "preserve",
            "drop",
            "error"
          ],
          "title": "Unknown Policy",
          "type": "string"
        },
        "output_column": {
          "default": "proforma_sequence",
          "title": "Output Column",
          "type": "string"
        },
        "map": {
          "items": {
            "$ref": "#/$defs/ModificationMapEntry"
          },
          "title": "Map",
          "type": "array"
        }
      },
      "required": [
        "parser",
        "source_column",
        "sequence_column"
      ],
      "title": "SeparateModColumnModifications",
      "type": "object"
    },
    "TokenRegexModifications": {
      "additionalProperties": false,
      "description": "Extract vendor modification tokens with a regex and map them to Unimod.\n\nThe only parser with a runtime implementation today (see\n``modifications.pipeline``).",
      "properties": {
        "parser": {
          "const": "token_regex",
          "title": "Parser",
          "type": "string"
        },
        "source_column": {
          "title": "Source Column",
          "type": "string"
        },
        "token_pattern": {
          "title": "Token Pattern",
          "type": "string"
        },
        "token_position": {
          "default": "after_residue",
          "enum": [
            "before_residue",
            "after_residue",
            "n_term",
            "c_term",
            "embedded",
            "unknown"
          ],
          "title": "Token Position",
          "type": "string"
        },
        "case_sensitive": {
          "default": false,
          "title": "Case Sensitive",
          "type": "boolean"
        },
        "unknown_policy": {
          "default": "preserve",
          "enum": [
            "preserve",
            "drop",
            "error"
          ],
          "title": "Unknown Policy",
          "type": "string"
        },
        "output_column": {
          "default": "proforma_sequence",
          "title": "Output Column",
          "type": "string"
        },
        "map": {
          "items": {
            "$ref": "#/$defs/ModificationMapEntry"
          },
          "minItems": 1,
          "title": "Map",
          "type": "array"
        }
      },
      "required": [
        "parser",
        "source_column",
        "token_pattern",
        "map"
      ],
      "title": "TokenRegexModifications",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "title": "Schema Version",
      "type": "string"
    },
    "file_version": {
      "title": "File Version",
      "type": "string"
    },
    "software_name": {
      "title": "Software Name",
      "type": "string"
    },
    "software_version": {
      "title": "Software Version",
      "type": "string"
    },
    "input_shape": {
      "enum": [
        "long",
        "wide"
      ],
      "title": "Input Shape",
      "type": "string"
    },
    "quantification_level": {
      "enum": [
        "ion",
        "peptidoform",
        "peptide",
        "protein",
        "fragment"
      ],
      "title": "Quantification Level",
      "type": "string"
    },
    "axis": {
      "$ref": "#/$defs/Axis"
    },
    "columns": {
      "$ref": "#/$defs/Columns"
    },
    "layers": {
      "items": {
        "$ref": "#/$defs/Layer"
      },
      "minItems": 1,
      "title": "Layers",
      "type": "array"
    },
    "sample_name_cleanup": {
      "anyOf": [
        {
          "$ref": "#/$defs/SampleNameCleanup"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "modifications": {
      "anyOf": [
        {
          "discriminator": {
            "mapping": {
              "already_proforma": "#/$defs/AlreadyProformaModifications",
              "separate_mod_column": "#/$defs/SeparateModColumnModifications",
              "token_regex": "#/$defs/TokenRegexModifications"
            },
            "propertyName": "parser"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/TokenRegexModifications"
            },
            {
              "$ref": "#/$defs/AlreadyProformaModifications"
            },
            {
              "$ref": "#/$defs/SeparateModColumnModifications"
            }
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Modifications"
    },
    "fragments": {
      "anyOf": [
        {
          "discriminator": {
            "mapping": {
              "column": "#/$defs/ColumnLabeledFragments",
              "positional": "#/$defs/PositionalFragments"
            },
            "propertyName": "label_strategy"
          },
          "oneOf": [
            {
              "$ref": "#/$defs/PositionalFragments"
            },
            {
              "$ref": "#/$defs/ColumnLabeledFragments"
            }
          ]
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fragments"
    }
  },
  "required": [
    "schema_version",
    "file_version",
    "software_name",
    "software_version",
    "input_shape",
    "quantification_level",
    "axis",
    "columns",
    "layers"
  ],
  "title": "ParseRule",
  "type": "object"
}
